// ═══════════════════════════════════════════════════════════════════
// LAYTIME & DEMURRAGE CALCULATIONS
// ═══════════════════════════════════════════════════════════════════

model LaytimeCalculation {
  id                 String   @id @default(cuid())
  userId             String
  orgId              String?

  // Charter party terms
  vesselName         String   @default("")
  voyageRef          String   @default("")
  portName           String   @default("")
  operationType      String   @default("loading") // loading | discharging
  laytimeMode        String   @default("fixed")   // fixed | rate
  allowedHours       Float    @default(72)
  cargoQuantity      Float?
  loadingRate        Float?
  terms              String   @default("SHINC")   // SHINC | SHEX | SSHEX | SHEXUU
  demurrageRate      Float    @default(25000)
  despatchRate       Float    @default(12500)
  norTendered        DateTime?
  laytimeCommenced   DateTime?
  reversible         Boolean  @default(false)

  // Time sheet events (JSON array)
  events             Json     @default("[]")

  // Computed results (cached for display in list views)
  resultType         String?  // "demurrage" | "despatch"
  resultAmount       Float?
  countedHours       Float?
  excludedHours      Float?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([orgId])
  @@index([userId])
}

