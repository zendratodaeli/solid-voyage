// ═══════════════════════════════════════════════════════════════════
// FLEET SCHEDULE FILTER PRESETS (Saved filter configurations)
// ═══════════════════════════════════════════════════════════════════

model FleetFilterPreset {
  id           String   @id @default(cuid())
  orgId        String   // Clerk Organization ID
  name         String   // e.g., "Cape open W. Africa 30d"
  filters      Json     // Serialized filter state: { sortKey, hideCompleted, vesselTypeFilter, dwtRange, ... }
