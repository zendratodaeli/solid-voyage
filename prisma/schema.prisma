  @@index([path])
  @@index([countryCode])
}

// ═══════════════════════════════════════════════════════════════════
// USER BEHAVIOR TRACKING
// ═══════════════════════════════════════════════════════════════════

model ActivityEvent {
  id        String   @id @default(cuid())
  userId    String   // Clerk user ID
  orgId     String?  // Organization ID (null for non-org actions)
  event     String   // "page_view" | "action" | "login" | "session_start"
  feature   String   // "route_planner" | "fleet_schedule" | "ais_dashboard" | "market_data" | "vessel_profiles" | "voyage_management" | "settings" | "admin" | "dashboard" | "general"
  action    String?  // Specific action: "create_voyage" | "view_route" | "update_vessel" etc.
  path      String?  // Page path
  metadata  String?  // JSON string for extra context
  duration  Int?     // Time spent in seconds (for session tracking)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([feature])
  @@index([createdAt])
  @@index([userId, feature])
  @@index([orgId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════
// MARITIME INTELLIGENCE (Admin-Managed Static Data)
// Singleton — stores periodically-updated industry benchmarks
// for canal tolls, war risk, hull values, commodity values, etc.
// ═══════════════════════════════════════════════════════════════════

model MaritimeIntelligence {
  id    String @id @default("maritime_intelligence")

  // ═══════════════════════════════════════════════════════════════
  // CANAL TARIFF RATES
  // Source: Suez Canal Authority, Panama Canal Authority, WSV Germany
  // Update: ~1-2x per year when canal authorities publish new circulars
  // ═══════════════════════════════════════════════════════════════

  // Suez Canal — Tiered SCNT rates ($/SCNT)
  suezTier1Rate         Float @default(7.88)   // 0–5,000 SCNT
  suezTier2Rate         Float @default(6.30)   // 5,001–10,000
  suezTier3Rate         Float @default(5.04)   // 10,001–20,000
  suezTier4Rate         Float @default(4.41)   // 20,001–30,000
  suezTier5Rate         Float @default(3.78)   // 30,000+
  suezBallastDiscount   Float @default(50)     // % discount for ballast passage
  suezTankerSurcharge   Float @default(10)     // % surcharge for tankers

  // Panama Canal — Tiered NT rates ($/NT)
  panamaTier1Rate       Float @default(5.40)   // 0–10,000 NT
  panamaTier2Rate       Float @default(4.32)   // 10,001–20,000
  panamaTier3Rate       Float @default(3.78)   // 20,000+
  panamaContainerPanamax    Float @default(95)   // $/TEU (Panamax locks)
  panamaContainerNeopanamax Float @default(110)  // $/TEU (Neopanamax locks)

  // Kiel Canal (EUR per 1000 GT, converted to USD via eurUsdRate)
  kielRatePer1000GT     Float @default(45)     // EUR/1000 GT

  // ═══════════════════════════════════════════════════════════════
  // WAR RISK & PIRACY INTELLIGENCE
  // Source: IMB Piracy Reporting Centre, Joint War Committee (JWC)
  // Update: ~1-2x per year (IMB annual report, JWC listed areas)
  // ═══════════════════════════════════════════════════════════════

  // Gulf of Aden HRA
  gulfAdenRiskScore       Int    @default(8)           // 1-10
  gulfAdenRiskLevel       String @default("HIGH")      // LOW | MODERATE | HIGH | CRITICAL
  gulfAdenIncidents12m    Int    @default(23)           // Incidents in last 12 months
  gulfAdenWarRiskRate     Float  @default(0.035)        // % of hull value per transit
  gulfAdenArmedGuards     String @default("RECOMMENDED") // NONE | RECOMMENDED | MANDATORY

  // West Africa HRA
  westAfricaRiskScore     Int    @default(7)
  westAfricaRiskLevel     String @default("HIGH")
  westAfricaIncidents12m  Int    @default(35)
  westAfricaWarRiskRate   Float  @default(0.025)
  westAfricaArmedGuards   String @default("RECOMMENDED")

  // Strait of Malacca HRA
  malaccaRiskScore        Int    @default(4)
  malaccaRiskLevel        String @default("MODERATE")
  malaccaIncidents12m     Int    @default(8)
  malaccaWarRiskRate      Float  @default(0.015)
  malaccaArmedGuards      String @default("NONE")

  // ═══════════════════════════════════════════════════════════════
  // HULL VALUE BENCHMARKS (by Vessel Type)
  // Source: VesselsValue, Clarksons, S&P market intelligence
  // Update: Quarterly
  // ═══════════════════════════════════════════════════════════════

  hullValueCapesize         Float @default(55000000)
  hullValuePanamax          Float @default(35000000)
  hullValueSupramax         Float @default(28000000)
  hullValueHandysize        Float @default(22000000)
  hullValueVLCC             Float @default(120000000)
  hullValueSuezmax          Float @default(70000000)
  hullValueAframax          Float @default(55000000)
  hullValueMRTanker         Float @default(40000000)
  hullValueLNGCarrier       Float @default(200000000)
  hullValueContainerFeeder  Float @default(25000000)
  hullValueContainerPanamax Float @default(45000000)
  hullValueGeneralCargo     Float @default(18000000)
  hullValueAgeDepreciation  Float @default(3.0)         // % per year
  hullValueMinAgeFactor     Float @default(0.50)         // Floor factor (50%)

  // ═══════════════════════════════════════════════════════════════
  // COMMODITY VALUES ($/MT for Cargo-at-Risk calculations)
  // Source: Platts, Reuters, CBOT, commodity exchanges
  // Update: Monthly to Quarterly
  // ═══════════════════════════════════════════════════════════════

  commodityIronOre        Float @default(120)
  commodityCoalThermal    Float @default(150)
  commodityCoalCoking     Float @default(280)
  commodityGrainWheat     Float @default(350)
  commodityGrainCorn      Float @default(250)
  commoditySoybeans       Float @default(450)
  commodityCrudeOil       Float @default(550)
  commodityCleanProducts  Float @default(700)
  commodityLNG            Float @default(800)
  commodityLPG            Float @default(500)
  commoditySteel          Float @default(700)
  commodityFertilizer     Float @default(400)
  commodityCement         Float @default(100)
  commodityContainerAvg   Float @default(35000)         // avg value per TEU
  commodityDefault        Float @default(300)            // fallback $/MT

  // ═══════════════════════════════════════════════════════════════
  // PORT CONGESTION PROFILES (avg wait days)
  // Source: Broker intelligence, MarineTraffic reports
  // Update: Quarterly to Semi-annually
  // ═══════════════════════════════════════════════════════════════

  congestionChinaQingdao     Float @default(3.5)
  congestionChinaTianjin     Float @default(4.0)
  congestionChinaQinhuangdao Float @default(5.0)
  congestionAustNewcastle    Float @default(2.0)
  congestionAustPortHedland  Float @default(1.5)
  congestionBrazilSantos     Float @default(3.0)
  congestionBrazilTubarao    Float @default(2.5)
  congestionIndiaMundra      Float @default(2.0)
  congestionIndiaKandla      Float @default(3.0)
  congestionUSGulfHouston    Float @default(2.0)
  congestionRotterdam        Float @default(0.5)
  congestionSingapore        Float @default(1.0)

  // ═══════════════════════════════════════════════════════════════
  // CURRENCY RATES
  // Source: ECB, Federal Reserve (manual for now, API-able later)
  // Update: Weekly to Monthly
  // ═══════════════════════════════════════════════════════════════

  eurUsdRate              Float @default(1.08)
  gbpUsdRate              Float @default(1.27)
  nokUsdRate              Float @default(0.093)

  // ─── Audit ─────────────────────────────────────────────────
  lastUpdatedAt           DateTime @updatedAt
  updatedBy               String?
}
