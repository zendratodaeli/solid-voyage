// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════
// USER & AUTHENTICATION (Clerk-based)
// ═══════════════════════════════════════════════════════════════════

model User {
  id             String     @id @default(cuid())
  clerkId        String     @unique // Clerk user ID
  email          String     @unique
  name           String?
  roles          UserRole[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  vessels        Vessel[]
  voyages        Voyage[]
  savedScenarios Scenario[]
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       RoleType
  isCustom   Boolean  @default(false)
  customName String?

  @@unique([userId, role])
}

enum RoleType {
  VESSEL_MANAGER
  SHIPBROKER
  VESSEL_OPERATOR
  OWNER_MANAGEMENT
  OTHER
}

// ═══════════════════════════════════════════════════════════════════
// ORGANIZATIONS (Clerk-synced)
// ═══════════════════════════════════════════════════════════════════

model Organization {
  id        String   @id          // Clerk org ID (e.g. "org_abc123")
  name      String
  slug      String?
  imageUrl  String?

  // ─── Logo Display Preferences ─────────────────────────────
  logoSize          Int      @default(64)    // Display size in px (32–128)
  logoBorderRadius  String   @default("md")  // "none" | "sm" | "md" | "lg" | "full"

  // ─── Organization Identity (Onboarding Gate) ──────────────
  profileComplete     Boolean  @default(false)
  companyLegalName    String?  // Full legal company name
  companyAddress      String?  // Street address
  companyCity         String?  // City
  companyCountry      String?  // Country
  companyPostalCode   String?  // Postal / ZIP code
  contactFullName     String?  // Primary contact full name
  contactNickname     String?  // Maritime nickname / call name
  contactPhone        String?  // Optional: phone number
  contactDepartment   String?  // Optional: "Chartering", "Operations", etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  theme     OrgTheme?
}

model OrgTheme {
  id           String   @id @default(cuid())
  orgId        String   @unique
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accentColor  String?  // Hex color e.g. "#6366f1"
  sidebarLabel String?  // Custom sidebar label override
  currency     String   @default("USD") // Display currency: USD, EUR, GBP, NOK

  // ─── AIS Dashboard Preferences ─────────────────────────────────
  aisAutoRefresh Boolean @default(false) // Auto-refresh fleet positions (costs API tokens)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════
// VESSEL DATA
// ═══════════════════════════════════════════════════════════════════

model Vessel {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId                 String?    // Clerk Organization ID for multi-tenancy

  name                  String
  imoNumber             String?    @unique
  mmsiNumber            String?    @unique  // MMSI for AIS tracking
  vesselType            VesselType
  customVesselType      String?    // For custom types when vesselType is OTHER
  dwt                   Float // Deadweight tonnage

  // ─── Vessel Dimensions ─────────────────────────────────────────
  loa                   Float?   // Length Overall (meters)
  beam                  Float?   // Beam / breadth (meters)
  summerDraft           Float?   // Summer draft (meters) — max loaded draft
  grossTonnage          Float?   // GT (Gross Tonnage) — for port dues & canal tolls
  netTonnage            Float?   // NT (Net Tonnage) — Suez/Panama fee basis

  // ─── Vessel Identification ─────────────────────────────────────
  yearBuilt             Int?     // Year of construction (for CII bands, vetting)
  flagState             String?  // Flag state (e.g., "Marshall Islands")
  classificationSociety String?  // e.g., "DNV", "Lloyd's Register"
  iceClass              String?  // e.g., "1A", "1B", "1C" — for Arctic/Baltic trades

  // ─── Capacity ──────────────────────────────────────────────────
  vesselConstant        Float?   // Weight of stores/crew/provisions (MT) — deducted from DWT for actual cargo intake

  // ─── Bulk Carrier / General Cargo Fields ───────────────────────
  grainCapacity         Float?   // Grain capacity (cbm) — bulk carriers
  baleCapacity          Float?   // Bale capacity (cbm) — general/break-bulk
  numberOfHolds         Int?     // Number of cargo holds
  numberOfHatches       Int?     // Number of cargo hatches
  grabFitted            Boolean? // Whether vessel has grabs for self-unloading

  // ─── Crane / Cargo Handling ────────────────────────────────────
  craneCount            Int?     // Number of cranes
  craneSWL              Float?   // Single crane Safe Working Load (MT)
  hasTweenDecks         Boolean? // Tween deck fitted (break-bulk)

  // ─── Container Ship Fields ─────────────────────────────────────
  teuCapacity           Int?     // TEU (Twenty-foot Equivalent Unit) capacity
  feuCapacity           Int?     // FEU (Forty-foot Equivalent Unit) capacity — alternative metric
  reeferPlugs           Int?     // Number of reefer container power slots

  // ─── Tanker Fields ─────────────────────────────────────────────
  tankCapacity          Float?   // Total cargo tank capacity (cbm)
  numberOfTanks         Int?     // Number of segregated cargo tanks
  coatedTanks           Boolean? // Epoxy/zinc coated tanks — determines eligible cargo
  heatingCoils          Boolean? // Cargo heating capability (viscous cargoes)
  pumpingRate           Float?   // Cargo pumping rate (cbm/hour)
  hasIGS                Boolean? // Inert Gas System
  hasCOW                Boolean? // Crude Oil Washing system
  hasSBT                Boolean? // Segregated Ballast Tanks

  // ─── LNG / LPG Carrier Fields ──────────────────────────────────
  cargoTankCapacityCbm  Float?   // LNG/LPG cargo tank capacity (cbm)
  containmentType       String?  // "MEMBRANE", "MOSS", "TYPE_C" — tank technology
  boilOffRate           Float?   // Daily boil-off rate (% of cargo per day, e.g. 0.10)
  dualFuelEngine        String?  // Engine type: "DFDE", "ME_GI", "X_DF", "STEAM"
  heelQuantity          Float?   // LNG heel retained on ballast (cbm)

  // Speed profiles (knots)
  ladenSpeed            Float
  ballastSpeed          Float
  ecoLadenSpeed         Float? // ECO profile laden speed
  ecoBallastSpeed       Float? // ECO profile ballast speed

  // Consumption profiles (MT/day)
  ladenConsumption      Float?
  ballastConsumption    Float?
  ecoLadenConsumption   Float?
  ecoBallastConsumption Float?
  portConsumptionWithCrane    Float? // Port consumption with crane operation
  portConsumptionWithoutCrane Float? // Port consumption without crane operation
  
  // Default fuel types for each consumption state (now String to support custom fuel types)
  ballastFuelType       String @default("VLSFO")
  ladenFuelType         String @default("VLSFO")
  portFuelType          String @default("LSMGO")
  
  // Fuel capabilities - list of ALL fuel types this vessel can burn
  fuelTypes             Json?    // Array: ["VLSFO", "LSMGO", "LNG"]
  
  // Per-fuel consumption profiles: { "VLSFO": { "laden": 14, "ballast": 11 }, "MGO": { "laden": 12, "ballast": 10 } }
  fuelConsumption       Json?

  // Commercial control & operating costs
  commercialControl     CommercialControl @default(OWNED_BAREBOAT)
  dailyOpex             Float?   @default(0) // USD/day — used for OPEX (owned) or Hire Rate (TC)
  
  // TC-In Hire (Time Charter-In)
  dailyTcHireRate       Float?   // USD/day — daily hire rate for TC-In vessels
  tcHireStartDate       DateTime?  // Charter period start
  tcHireEndDate         DateTime?  // Charter period end

  // Equipment
  hasScrubber           Boolean  @default(false) // EGCS (Exhaust Gas Cleaning System) fitted

  // Audit trail (denormalized for fast display)
  createdByName         String?  // Name of user who created this vessel
  updatedByName         String?  // Name of user who last updated this vessel

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  voyages               Voyage[]
  inquiryCandidates     InquiryVesselCandidate[]

  @@index([orgId])
}

enum VesselType {
  // ─── Bulk Carriers ───────────────────
  CAPESIZE
  PANAMAX
  POST_PANAMAX
  SUPRAMAX
  HANDYMAX
  HANDYSIZE
  BULK_CARRIER        // Generic bulk

  // ─── Tankers ────────────────────────
  VLCC                // Very Large Crude Carrier
  SUEZMAX
  AFRAMAX
  MR_TANKER           // Medium Range
  LR1_TANKER          // Long Range 1
  LR2_TANKER          // Long Range 2
  CHEMICAL_TANKER
  PRODUCT_TANKER

  // ─── Container Ships ────────────────
  CONTAINER_FEEDER    // < 3,000 TEU
  CONTAINER_PANAMAX   // 3,000–5,100 TEU
  CONTAINER_POST_PANAMAX // 5,100–10,000 TEU
  CONTAINER_ULCV      // Ultra Large > 10,000 TEU

  // ─── Gas Carriers ───────────────────
  LNG_CARRIER
  LPG_CARRIER

  // ─── General Cargo / Specialized ────
  GENERAL_CARGO
  MULTI_PURPOSE
  HEAVY_LIFT
  CAR_CARRIER         // PCC / PCTC (Ro-Ro)
  RO_RO               // Roll-on/Roll-off

  OTHER
}

enum CommercialControl {
  OWNED_BAREBOAT
  TIME_CHARTER
  VOYAGE_CHARTER
}

enum FreightRateUnit {
  PER_MT          // $/MT — bulk, tanker
  PER_TEU         // $/TEU — container
  PER_CBM         // $/cbm — LNG, LPG
  LUMP_SUM        // Flat rate — project cargo
  WORLDSCALE      // WS — tanker market
}

// ═══════════════════════════════════════════════════════════════════
// PORTS & DISTANCES
// Source: NGA World Port Index (Pub 150) — 3,700+ ports worldwide
// Seeded from NGA, managed via Admin CMS
// ═══════════════════════════════════════════════════════════════════

model Port {
  id              String        @id @default(cuid())
  name            String
  locode          String        @unique  // UN/LOCODE e.g., "DEHAM"
  country         String
  region          Region?
  latitude        Float
  longitude       Float

  // Port cost defaults
  defaultPortDays Float         @default(2)

  // NGA World Port Index fields
  portNumber      Int?          @unique  // NGA port number
  harborSize      String        @default("M") // V(ery small) | S(mall) | M(edium) | L(arge)
  waterBody       String?       // Water body description
  alternateName   String?       // Alternate names (semicolon-separated)
  isActive        Boolean       @default(true)   // Super admin toggle
  lastSyncedAt    DateTime?     // When last synced from NGA

  bunkerPrices    BunkerPrice[]
  
  @@index([name])
  @@index([country])
  @@index([harborSize])
  @@index([latitude, longitude])
}

enum Region {
  NORTH_AMERICA
  SOUTH_AMERICA
  EUROPE
  MEDITERRANEAN
  MIDDLE_EAST
  WEST_AFRICA
  EAST_AFRICA
  SOUTH_AFRICA
  INDIAN_SUBCONTINENT
  SOUTHEAST_ASIA
  EAST_ASIA
  AUSTRALIA
  PACIFIC
}

model PortDistance {
  id                String     @id @default(cuid())
  originPortId      String
  destinationPortId String
  distanceNm        Float // Nautical miles
  viaCanal          CanalType?

  @@unique([originPortId, destinationPortId, viaCanal])
}

enum CanalType {
  SUEZ
  PANAMA
  NONE
}

// ═══════════════════════════════════════════════════════════════════
// BUNKER PRICES
// ═══════════════════════════════════════════════════════════════════

model BunkerPrice {
  id       String   @id @default(cuid())
  portId   String
  port     Port     @relation(fields: [portId], references: [id])
  fuelType FuelType
  price    Float // USD/MT
  date     DateTime @default(now())

  @@index([portId, fuelType, date])
}

enum FuelType {
  VLSFO // Very Low Sulphur Fuel Oil
  HSFO // High Sulphur Fuel Oil
  HFO // Heavy Fuel Oil
  MGO // Marine Gas Oil
  LSMGO // Low Sulphur Marine Gas Oil
  LNG // Liquefied Natural Gas
}

// ═══════════════════════════════════════════════════════════════════
// VOYAGE & CALCULATION
// ═══════════════════════════════════════════════════════════════════

model Voyage {
  id                    String                 @id @default(cuid())
  userId                String
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId                 String?                // Clerk Organization ID for multi-tenancy
  vesselId              String
  vessel                Vessel                 @relation(fields: [vesselId], references: [id])

  // Route - simple text fields for flexibility
  openPort              String?  // Where the vessel is now (start position)
  loadPort              String  // e.g., "Rotterdam, Netherlands"
  dischargePort         String  // e.g., "Singapore"

  // Multi-port voyage legs (JSON array for flexible multi-stop routes)
  // Structure: { loadPorts: string[], dischargePorts: string[] }
  voyageLegs            Json?

  // Cargo
  cargoQuantityMt       Float // Metric tons
  cargoType             String?  // e.g., "Iron Ore", "Crude Oil", "Containers"
  stowageFactor         Float?   // cbm/MT — for volume-limited cargo detection

  // Freight rate configuration
  freightRateUnit       FreightRateUnit @default(PER_MT)  // $/MT, $/TEU, Lump Sum, Worldscale

  // Distances (can be auto-calculated or manual)
  ballastDistanceNm     Float
  ladenDistanceNm       Float

  // Port operations
  loadPortDays          Float
  dischargePortDays     Float
  waitingDays           Float                  @default(0)
  idleDays              Float                  @default(0)

  // Speed selection
  useEcoSpeed           Boolean                @default(false)

  // Speed override (allows per-voyage speed adjustment)
  overrideLadenSpeed    Float?
  overrideBallastSpeed  Float?
  
  // Crane usage (affects port consumption calculation)
  useCrane              Boolean                @default(false)

  // Canal
  canalType             CanalType              @default(NONE)
  canalTolls            Float                  @default(0)

  // Bunker prices (multi-fuel support)
  bunkerPriceUsd        Float  // Legacy: single fuel price (deprecated, kept for backward compatibility)
  bunkerFuelType        FuelType               @default(VLSFO)
  fuelPrices            Json?  // Dynamic fuel prices: { "VLSFO": 555, "LSMGO": 785 }
  
  // Fuel type overrides for this voyage (defaults from vessel if not set)
  // Using String instead of FuelType enum to support custom fuel types
  ladenFuelType         String?
  ballastFuelType       String?
  portFuelType          String?

  // Costs
  brokeragePercent      Float                  @default(1.25)
  commissionPercent     Float                  @default(3.75)
  additionalCosts       Float                  @default(0)
  pdaCosts              Float                  @default(0)  // Proforma Disbursement Account
  lubOilCosts           Float                  @default(0)  // Lubricating Oil & Cylinder Lub Oil

  // Weather adjustment
  weatherRiskMultiplier Float                  @default(1.0)

  // Freight (input for calculation)
  freightRateUsd        Float? // USD/MT offered

  // EU ETS Compliance
  loadPortCountryCode      String?  // ISO country code e.g. "NL"
  dischargePortCountryCode String?  // ISO country code e.g. "SG"
  euEtsApplicable          Boolean  @default(false)
  euEtsPercentage          Int      @default(0) // 0, 50, or 100

  // ─── Laycan (loading window, synced with cargo inquiry) ────────
  laycanStart              DateTime?              // Earliest loading date
  laycanEnd                DateTime?              // Latest cancelling date

  // ─── Fleet Scheduling ─────────────────────────────────────────
  estimatedDeparture    DateTime?              // When vessel departs open port
  estimatedArrival      DateTime?              // When vessel arrives at final discharge
  actualDeparture       DateTime?              // Actual departure (for IN_EXECUTION voyages)
  actualArrival         DateTime?              // Actual arrival (for COMPLETED voyages)
  redeliveryPort        String?                // Where vessel is free after this voyage
  redeliveryDate        DateTime?              // When vessel becomes available

  // Status
  status                VoyageStatus           @default(DRAFT)

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  calculations          VoyageCalculation?
  recommendations       FreightRecommendation?
  actuals               VoyageActual?
  scenarios             Scenario[]
  shares                VoyageShare[]          // Per-voyage sharing permissions
  comments              VoyageComment[]        // Discussion comments

  @@index([orgId])
}

enum VoyageStatus {
  DRAFT
  NEW           // Cargo being evaluated (was ANALYZING)
  OFFERED       // In negotiation (was RECOMMENDED)
  FIXED         // Deal confirmed — actual data fields unlock
  COMPLETED     // Voyage delivered
  REJECTED      // Internal decision (not profitable)
  LOST          // Competitor won
  EXPIRED       // Laycan passed
  WITHDRAWN     // Client pulled out
}

// ═══════════════════════════════════════════════════════════════════
// CALCULATION RESULTS (Stored for audit & comparison)
// ═══════════════════════════════════════════════════════════════════

model VoyageCalculation {
  id               String   @id @default(cuid())
  voyageId         String   @unique
  voyage           Voyage   @relation(fields: [voyageId], references: [id], onDelete: Cascade)

  // Duration breakdown
  ballastSeaDays   Float
  ladenSeaDays     Float
  totalSeaDays     Float
  totalPortDays    Float
  totalVoyageDays  Float

  // Bunker breakdown
  ballastBunkerMt  Float
  ladenBunkerMt    Float
  portBunkerMt     Float
  totalBunkerMt    Float
  totalBunkerCost  Float

  // Cost breakdown
  opexCost         Float
  canalCost        Float
  brokerageCost    Float
  commissionCost   Float
  additionalCost   Float
  totalVoyageCost  Float

  // Revenue & Profitability
  grossRevenue     Float? // Based on offered freight
  netRevenue       Float?
  voyagePnl        Float?
  tce              Float // Time Charter Equivalent
  breakEvenFreight Float // USD/MT

  // TC-In Hire deduction
  tcHireCost       Float?    // Total TC hire for voyage duration (dailyRate × days)
  tcHireDailyRate  Float?    // Daily rate used
  grossTce         Float?    // TCE before hire deduction
  netTce           Float?    // TCE after hire deduction (= tce when no hire)

  // EU ETS + Carbon
  totalCO2Mt       Float?    // Total CO₂ emissions (metric tonnes)
  euEtsCost        Float?    // Carbon tax cost (USD)
  euEtsPercentage  Int?      // 0, 50, or 100% taxable

  // CII Impact
  ciiAttained      Float?    // gCO₂/(dwt·nm)
  ciiRequired      Float?    // gCO₂/(dwt·nm) for this year
  ciiRating        String?   // "A", "B", "C", "D", "E"
  ciiRatio         Float?    // attained / required

  calculatedAt     DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════════
// VOYAGE ACTUALS (Post-Execution Real Data)
// ═══════════════════════════════════════════════════════════════════

model VoyageActual {
  id               String   @id @default(cuid())
  voyageId         String   @unique
  voyage           Voyage   @relation(fields: [voyageId], references: [id], onDelete: Cascade)

  // Duration actuals
  ballastSeaDays   Float
  ladenSeaDays     Float
  totalSeaDays     Float
  totalPortDays    Float
  totalVoyageDays  Float

  // Bunker actuals
  totalBunkerMt    Float
  totalBunkerCost  Float

  // Cost actuals
  totalVoyageCost  Float

  // Revenue & Profitability actuals
  grossRevenue     Float?
  voyagePnl        Float?
  tce              Float?

  // Operator notes
  notes            String?  @db.Text

  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════
// FREIGHT RECOMMENDATION
// ═══════════════════════════════════════════════════════════════════

model FreightRecommendation {
  id                   String               @id @default(cuid())
  voyageId             String               @unique
  voyage               Voyage               @relation(fields: [voyageId], references: [id], onDelete: Cascade)

  // Freight levels (USD/MT)
  breakEvenFreight     Float
  targetFreight        Float // With margin
  minMarketFreight     Float // Market range low
  maxMarketFreight     Float // Market range high
  recommendedFreight   Float // Final recommendation

  // Margins
  targetMarginPercent  Float
  targetMarginUsd      Float

  // Risk assessment
  overallRisk          RiskLevel
  bunkerVolatilityRisk RiskLevel
  weatherRisk          RiskLevel
  marketAlignmentRisk  RiskLevel

  // Decision support
  confidenceScore      Float // 0-100
  explanation          String               @db.Text
  assumptions          Json // Key assumptions used

  // Action recommendation
  recommendation       RecommendationAction

  createdAt            DateTime             @default(now())
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum RecommendationAction {
  STRONG_ACCEPT
  ACCEPT
  NEGOTIATE
  REJECT
  STRONG_REJECT
}

// ═══════════════════════════════════════════════════════════════════
// SCENARIO COMPARISON
// ═══════════════════════════════════════════════════════════════════

model Scenario {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId       String?  // Clerk Organization ID for multi-tenancy
  voyageId    String
  voyage      Voyage   @relation(fields: [voyageId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // Overrides from base voyage
  overrides   Json // { ladenSpeed: 12, bunkerPriceUsd: 550, ... }

  // Calculated results
  results     Json // Full calculation results

  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════════
// WEATHER RISK PROFILES
// ═══════════════════════════════════════════════════════════════════

model SeasonalWeatherProfile {
  id                    String  @id @default(cuid())
  tradeRoute            String // e.g., "AG-FEAST" (Arabian Gulf to Far East)
  month                 Int // 1-12

  averageRiskMultiplier Float // 1.0 = normal, 1.15 = 15% buffer
  additionalSeaDays     Float // Extra days to account for
  description           String?

  @@unique([tradeRoute, month])
}

// ═══════════════════════════════════════════════════════════════════
// MARKET RATE BENCHMARKS
// ═══════════════════════════════════════════════════════════════════

model MarketBenchmark {
  id          String     @id @default(cuid())
  tradeRoute  String
  vesselType  VesselType
  freightRate Float // USD/MT
  tcRate      Float? // USD/day TC equivalent
  date        DateTime   @default(now())
  source      String? // e.g., "Baltic Exchange", "Manual"

  @@index([tradeRoute, vesselType, date])
}

// ═══════════════════════════════════════════════════════════════════
// SYSTEM PRICING (Singleton for Global Fuel Benchmarks)
// ═══════════════════════════════════════════════════════════════════

model SystemPricing {
  id                   String   @id @default("system_pricing")
  
  // ═══════════════════════════════════════════════════════════════════
  // FUEL PRICES (USD/MT)
  // ═══════════════════════════════════════════════════════════════════
  
  // Distillates / ECA Compliant
  globalLSMGOAverage   Float    @default(0)  // USD/MT (0.1% Sulfur)
  
  // Residuals
  globalVLSFOAverage   Float    @default(0)  // USD/MT (0.5% Sulfur)
  globalIFO380Average  Float    @default(0)  // USD/MT (High Sulfur)
  globalIFO180Average  Float    @default(0)  // USD/MT (High Sulfur)
  
  // Alternative Fuels
  globalLNGAverage     Float    @default(0)  // USD/MT
  
  // Regulatory / Carbon Pricing
  globalEUAPrice       Float    @default(75.00)  // EU ETS Carbon Price (USD/MT CO2)
  
  // ═══════════════════════════════════════════════════════════════════
  // CARBON EMISSION FACTORS (MT CO2 per MT Fuel) - IMO MEPC.308
  // ═══════════════════════════════════════════════════════════════════
  
  carbonFactorVLSFO    Float    @default(3.114)   // Very Low Sulfur Fuel Oil
  carbonFactorLSMGO    Float    @default(3.206)   // Low Sulfur Marine Gas Oil
  carbonFactorIFO380   Float    @default(3.114)   // Heavy Fuel Oil
  carbonFactorIFO180   Float    @default(3.114)   // Intermediate Fuel Oil
  carbonFactorLNG      Float    @default(3.160)   // Liquefied Natural Gas
  carbonFactorMETHANOL Float    @default(1.375)   // Methanol
  carbonFactorAMMONIA  Float    @default(0.050)   // Ammonia (Very Low Carbon)
  
  lastUpdatedAt        DateTime @updatedAt
  updatedBy            String?
}

// ═══════════════════════════════════════════════════════════════════
// ORG PRICING (Per-Organization Fuel Benchmarks)
// Seeded from SystemPricing on first access, then independently managed
// ═══════════════════════════════════════════════════════════════════

model OrgPricing {
  id                   String   @id @default(cuid())
  orgId                String   @unique  // Clerk Organization ID — one record per org

  // Fuel Prices (USD/MT)
  globalLSMGOAverage   Float    @default(0)
  globalVLSFOAverage   Float    @default(0)
  globalIFO380Average  Float    @default(0)
  globalIFO180Average  Float    @default(0)
  globalLNGAverage     Float    @default(0)
  globalEUAPrice       Float    @default(75.00)

  // Carbon Emission Factors (MT CO2 per MT Fuel) - IMO MEPC.308
  carbonFactorVLSFO    Float    @default(3.114)
  carbonFactorLSMGO    Float    @default(3.206)
  carbonFactorIFO380   Float    @default(3.114)
  carbonFactorIFO180   Float    @default(3.114)
  carbonFactorLNG      Float    @default(3.160)
  carbonFactorMETHANOL Float    @default(1.375)
  carbonFactorAMMONIA  Float    @default(0.050)

  lastUpdatedAt        DateTime @updatedAt
  updatedBy            String?

  @@index([orgId])
}

// ═══════════════════════════════════════════════════════════════════
// STRATEGIC PASSAGES (Canals & Straits)
// ═══════════════════════════════════════════════════════════════════

model StrategicPassage {
  id              String   @id @default(cuid())
  name            String   @unique  // "Kiel Canal", "Sunda Strait"
  displayName     String   // "Kiel Canal (Germany)"
  type            String   // "canal" | "strait"
  region          String   // "Europe", "Asia", "Global"
  
  // Entry coordinates
  entryLat        Float
  entryLng        Float
  entryName       String   // "Brunsbüttel"
  
  // Exit coordinates
  exitLat         Float
  exitLng         Float
  exitName        String   // "Holtenau"
  
  // Safety restrictions
  maxDraft        Float?   // Max draft in meters (null = no restriction)
  restriction     String?  // Description of restriction
  
