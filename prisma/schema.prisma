// ═══════════════════════════════════════════════════════════════════
// CARGO INQUIRY BOARD (Commercial Pipeline)
// ═══════════════════════════════════════════════════════════════════

model CargoInquiry {
  id                String   @id @default(cuid())
  orgId             String

  // ─── Cargo Details ──────────────────────────────────
  cargoType         String            // "Coal", "Iron Ore", "Grain"
  cargoQuantityMt   Float             // 65000
  stowageFactor     Float?            // m³/MT — e.g., 1.3 for grain
  cubicCapacityReq  Float?            // Auto: qty × SF

  // ─── Route ──────────────────────────────────────────
  loadPort          String            // "Richards Bay"
  dischargePort     String            // "ARA"
  loadRegion        String?           // "West Africa" — for analytics
  dischargeRegion   String?           // "Europe"

  // ─── Laycan ─────────────────────────────────────────
  laycanStart       DateTime?         // May 5
  laycanEnd         DateTime?         // May 10

  // ─── Commercial ─────────────────────────────────────
  freightOffered    Float?            // $/MT offered by charterer
  freightCountered  Float?            // $/MT our latest counter-offer
  commissionPercent Float?            // Broker commission %
  estimatedRevenue  Float?            // freightOffered × cargoQuantity (auto-calculated)

  // ─── Negotiation History ────────────────────────────
  // JSON array: [{ round: 1, theirOffer: 14.50, ourCounter: 15.20, date: "...", note: "..." }]
  negotiationRounds Json?

  // ─── Source / Contact ───────────────────────────────
  source            String?           // "Broker A via email", "Direct", etc.
  brokerName        String?           // Named broker/company for scorecard
  contactName       String?           // Individual contact person
  contactEmail      String?           // Contact email

  // ─── Status Pipeline ────────────────────────────────
  // NEW → EVALUATING → OFFERED → NEGOTIATING → FIXED → LOST → EXPIRED → WITHDRAWN
  status            String  @default("NEW")

  // ─── Urgency (auto-calculated in UI from laycan proximity) ──
  // "URGENT" (<3d) | "ACTIVE" (3-7d) | "PLANNING" (7+d) | "OVERDUE" (past)
  priority          String?

  // ─── Vessel Linkage ─────────────────────────────────
  // The vessel finally selected (after multi-vessel evaluation)
  selectedVesselId  String?
  voyageId          String?           // Created when FIXED → becomes a real voyage

  // ─── Notes & Outcome ────────────────────────────────
  notes             String?
  rejectionReason   String?           // Why lost/expired/withdrawn

  // ─── Assignment & Audit ─────────────────────────────
  createdBy         String            // Clerk user ID
  createdByName     String?           // Denormalized for display
  assignedTo        String?           // Clerk user ID of assigned charterer
  assignedToName    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // ─── Relations ──────────────────────────────────────
  vesselCandidates  InquiryVesselCandidate[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([selectedVesselId])
  @@index([laycanStart])
}

// Multi-vessel evaluation: track candidate vessels per inquiry
model InquiryVesselCandidate {
  id          String   @id @default(cuid())
  inquiryId   String
  inquiry     CargoInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  vesselId    String
  vessel      Vessel   @relation(fields: [vesselId], references: [id])

  // Evaluation data
  estimatedTce  Float?    // Calculated TCE for this vessel + inquiry combo
  notes         String?   // "Good fit, but opens 2 days late"
  isSelected    Boolean   @default(false)  // The one ultimately picked
  evaluatedAt   DateTime  @default(now())
  evaluatedBy   String?   // Clerk user ID

  @@unique([inquiryId, vesselId])
  @@index([inquiryId])
  @@index([vesselId])
}

// ═══════════════════════════════════════════════════════════════════
// VOYAGE SHARING (Per-Voyage Permissions)
// ═══════════════════════════════════════════════════════════════════

model VoyageShare {
  id         String   @id @default(cuid())
  voyageId   String
  voyage     Voyage   @relation(fields: [voyageId], references: [id], onDelete: Cascade)
  sharedWith String   // Clerk user ID of the member
  permission String   // "view" | "update"
  createdAt  DateTime @default(now())

  @@unique([voyageId, sharedWith])
  @@index([sharedWith])
}

// ═══════════════════════════════════════════════════════════════════
// ACTIVITY AUDIT LOG
// ═══════════════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())
  orgId      String   // Clerk Organization ID
  entityType String   // "vessel" | "voyage"
  entityId   String
  entityName String   // Display name (e.g. vessel name)
  action     String   // "created" | "updated" | "deleted" | "shared"
  userId     String   // Who performed the action
  userName   String   // Denormalized for fast display
  changes    Json?    // { field: { from, to } } for updates
  createdAt  DateTime @default(now())

  @@index([orgId, entityType, entityId])
  @@index([orgId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════
// CUSTOM WEATHER LOCATIONS (Per-User)
