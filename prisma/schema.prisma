// ═══════════════════════════════════════════════════════════════════
// VISITOR ANALYTICS
// ═══════════════════════════════════════════════════════════════════

model PageView {
  id          String   @id @default(cuid())
  path        String   // e.g., "/", "/pages/contact"
  ip          String?  // visitor IP (hashed for privacy)
  country     String?  // e.g., "United States"
  countryCode String?  // e.g., "US"
  city        String?  // e.g., "New York"
  region      String?  // e.g., "New York"
  timezone    String?  // e.g., "America/New_York"
  org         String?  // ISP/company e.g., "AS14061 DigitalOcean"
  latitude    Float?
  longitude   Float?
  userAgent   String?  // raw UA string
  device      String?  // "desktop" | "mobile" | "tablet"
  browser     String?  // e.g., "Chrome 120"
  os          String?  // e.g., "Windows 11"
